# ===========================================
# Supabase Configuration
# ===========================================
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
#
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# Optional: Supabase Service Role Key
# ===========================================
# Only needed for server-side admin operations (e.g., managing users)
# NEVER expose this in the browser — server-side only!
#
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# Site Password Gate
# ===========================================
# Simple password to restrict access to the site during development
SITE_PASSWORD=ohio
