{
  "$schema_version": 1,
  "description": "Instrument packs per plan §6. Per-role gains are tuned for unison playback against compileTheme's master gain (0.45). Goal: every section-A role should be individually distinguishable when all 6 play together. Adjust master gain in musicCompiler.js if you change targets here.",
  "packs": {
    "fm_90s": {
      "id": "fm_90s",
      "name": "FM-Era 90s",
      "description": "Sega Genesis-style FM synthesis. Bell-like leads, FM-brass chords, harmonically rich tones — totally different timbre from gameboy chiptune.",
      "roles": {
        "bass": {
          "synth": "Tone.FMSynth",
          "options": {
            "harmonicity":     1.5,
            "modulationIndex": 8,
            "oscillator":      { "type": "sine" },
            "envelope":        { "attack": 0.005, "decay": 0.15, "sustain": 0.35, "release": 0.15 },
            "modulation":      { "type": "square" },
            "modulationEnvelope": { "attack": 0.005, "decay": 0.1, "sustain": 0.3, "release": 0.1 }
          },
          "gain": 0.55
        },
        "melody": {
          "synth": "Tone.FMSynth",
          "options": {
            "harmonicity":     3,
            "modulationIndex": 10,
            "oscillator":      { "type": "sine" },
            "envelope":        { "attack": 0.002, "decay": 0.12, "sustain": 0.5, "release": 0.1 },
            "modulation":      { "type": "sine" },
            "modulationEnvelope": { "attack": 0.005, "decay": 0.15, "sustain": 0.5, "release": 0.15 }
          },
          "gain": 0.65
        },
        "chords": {
          "synth":     "Tone.PolySynth",
          "baseSynth": "Tone.FMSynth",
          "options": {
            "harmonicity":     2,
            "modulationIndex": 6,
            "envelope":        { "attack": 0.02, "decay": 0.25, "sustain": 0.55, "release": 0.3 }
          },
          "gain": 0.55
        },
        "pad": {
          "synth":     "Tone.PolySynth",
          "baseSynth": "Tone.FMSynth",
          "options": {
            "harmonicity":     1,
            "modulationIndex": 4,
            "envelope":        { "attack": 0.4, "decay": 0.5, "sustain": 0.8, "release": 1.0 }
          },
          "gain": 0.5
        },
        "drums": {
          "recipes": {
            "kick":       { "synth": "Tone.MembraneSynth", "options": { "pitchDecay": 0.05, "octaves": 2.5, "envelope": { "attack": 0.001, "decay": 0.16, "sustain": 0, "release": 0.16 } }, "note": "C3", "trigger_note": "C3", "gain": 1.0 },
            "snare":      { "synth": "Tone.NoiseSynth",    "options": { "noise": { "type": "white" }, "envelope": { "attack": 0.001, "decay": 0.12, "sustain": 0, "release": 0.06 } }, "trigger_note": "D3", "gain": 0.75 },
            "hat_closed": { "synth": "Tone.MetalSynth",    "options": { "frequency": 200, "envelope": { "attack": 0.001, "decay": 0.05, "sustain": 0, "release": 0.02 }, "harmonicity": 5.1, "modulationIndex": 32, "resonance": 4000, "octaves": 1.5 }, "note": "C5", "trigger_note": "E3", "gain": 0.9 },
            "hat_open":   { "synth": "Tone.MetalSynth",    "options": { "frequency": 200, "envelope": { "attack": 0.001, "decay": 0.22, "sustain": 0, "release": 0.08 }, "harmonicity": 5.1, "modulationIndex": 32, "resonance": 4000, "octaves": 1.5 }, "note": "C5", "trigger_note": "F3", "gain": 0.8 }
          },
          "default_recipe": "kick"
        },
        "texture": {
          "synth": "Tone.NoiseSynth",
